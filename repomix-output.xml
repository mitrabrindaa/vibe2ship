      background: radial-gradient(ellipse at 0% 0%, rgba(168,85,247,0.12), transparent 60%);
      pointer-events: none;
    }

    .action-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
