  <script>
    // ── Wave animation ──────────────────────────────────────────────────────
    const canvas = document.getElementById('wave-canvas');
    const ctx = canvas.getContext('2d');
    let W, H, t = 0;

    function resize() {
      W = canvas.width  = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    const waves = [
      { amp: 60, freq: 0.008, speed: 0.012, color: '#7c3aed', y: 0.55 },
      { amp: 45, freq: 0.010, speed: 0.018, color: '#a855f7', y: 0.62 },
      { amp: 35, freq: 0.014, speed: 0.010, color: '#ec4899', y: 0.70 },
      { amp: 50, freq: 0.006, speed: 0.022, color: '#06b6d4', y: 0.48 },
    ];

    function drawWave(wave, time) {
      ctx.beginPath();
      ctx.moveTo(0, H);
      for (let x = 0; x <= W; x += 4) {
        const y = wave.y * H + Math.sin(x * wave.freq + time * wave.speed * 60) * wave.amp
                             + Math.sin(x * wave.freq * 1.7 + time * wave.speed * 40) * (wave.amp * 0.4);
        ctx.lineTo(x, y);
      }
      ctx.lineTo(W, H);
      ctx.closePath();
      const grad = ctx.createLinearGradient(0, 0, 0, H);
      grad.addColorStop(0, wave.color + '55');
      grad.addColorStop(1, wave.color + '00');
      ctx.fillStyle = grad;
      ctx.fill();
    }

    function animate(ts) {
      t = ts / 1000;
      ctx.clearRect(0, 0, W, H);
      waves.forEach(w => drawWave(w, t));
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);

    // ── API call ────────────────────────────────────────────────────────────
    const btn       = document.getElementById('execute-btn');
    const textarea  = document.getElementById('brain-dump');
    const resultSec = document.getElementById('result-section');
    const errBanner = document.getElementById('error-banner');

    function setLoading(on) {
      btn.disabled = on;
      btn.querySelector('.btn-content').classList.toggle('loading', on);
      btn.querySelector('.btn-text').textContent = on ? 'Analyzing' : '⚡ Execute';
    }

    function showError(msg) {
      errBanner.textContent = '⚠ ' + msg;
      errBanner.classList.add('visible');
    }
    function clearError() { errBanner.classList.remove('visible'); }

    function animateUrgency(value) {
      const pct = Math.min(100, (value / 10) * 100);
      // tiny delay so CSS transition fires
      setTimeout(() => {
        document.getElementById('urgency-bar').style.width = pct + '%';
      }, 80);
    }

    btn.addEventListener('click', async () => {
      const input = textarea.value.trim();
      if (!input) {
        showError('Please enter some text in the brain dump area first.');
        return;
      }
      clearError();
      resultSec.classList.remove('visible');
      setLoading(true);

      try {
        const res = await fetch('http://localhost:8000/api/plan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_input: input }),
        });

        if (!res.ok) {
          const errData = await res.json().catch(() => ({}));
          throw new Error(errData.detail || `Server error ${res.status}`);
        }

        const data = await res.json();

        document.getElementById('task-name').textContent    = data.task_name;
        document.getElementById('urgency-value').textContent = data.urgency_rating.toFixed(1);
        document.getElementById('time-value').textContent    = data.time_estimate_hours.toFixed(1);
        document.getElementById('action-text').textContent   = data.immediate_micro_action;

        animateUrgency(data.urgency_rating);

        // Force re-animation
        resultSec.classList.remove('visible');
        void resultSec.offsetWidth;
        resultSec.classList.add('visible');

      } catch (err) {
        showError(err.message || 'Something went wrong. Is the backend running?');
      } finally {
        setLoading(false);
      }
    });

    // Allow Ctrl+Enter to submit
    textarea.addEventListener('keydown', e => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) btn.click();
    });
  </script>
</body>
</html>
