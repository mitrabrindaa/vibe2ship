    }
    .action-label::before { content: '▶'; font-size: 0.6rem; }

    #action-text {
      font-size: 1.05rem;
      font-weight: 500;
      line-height: 1.6;
      color: var(--text-primary);
    }

    /* ── Error banner ────────────────────────────────────────────────── */
    #error-banner {
      display: none;
      width: 100%;
      background: rgba(244,63,94,0.12);
      border: 1px solid rgba(244,63,94,0.3);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      color: #fda4af;
      font-size: 0.9rem;
      animation: fade-up 0.4s ease both;
    }
    #error-banner.visible { display: block; }

    /* ── Footer ──────────────────────────────────────────────────────── */
    footer {
      margin-top: 1rem;
      text-align: center;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.2);
    }
    footer span { color: rgba(168,85,247,0.6); }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @media (max-width: 520px) {
      .glass-card { padding: 1.4rem; }
      .metrics-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
