    }
    #brain-dump::placeholder { color: rgba(255,255,255,0.28); }
    #brain-dump:focus {
      border-color: rgba(168,85,247,0.55);
      box-shadow: 0 0 0 3px rgba(168,85,247,0.15);
    }

    /* ── Execute button ──────────────────────────────────────────────── */
    #execute-btn {
      margin-top: 1.25rem;
      width: 100%;
      padding: 0.95rem 1.5rem;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: #fff;
      background: linear-gradient(135deg, var(--accent1) 0%, var(--accent3) 100%);
      border: none;
      border-radius: 14px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: transform 0.18s, box-shadow 0.18s;
      box-shadow: 0 4px 24px rgba(124,58,237,0.4);
    }
    #execute-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 60%);
      border-radius: inherit;
    }
    #execute-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(124,58,237,0.55);
    }
    #execute-btn:active:not(:disabled) { transform: translateY(0); }
    #execute-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .btn-content { display: flex; align-items: center; justify-content: center; gap: 10px; position: relative; }

    /* ── Spinner ─────────────────────────────────────────────────────── */
    .spinner {
      width: 18px; height: 18px;
      border: 2px solid rgba(255,255,255,0.25);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: none;
    }
    .loading .spinner { display: block; }
    .loading .btn-text::after { content: '…'; animation: ellipsis 1.2s steps(4, end) infinite; }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes ellipsis { 0%,20%{content:'.'} 40%{content:'..'} 60%,80%{content:'...'} 100%{content:'.'} }

    /* ── Result card ─────────────────────────────────────────────────── */
    #result-section {
      width: 100%;
      display: none;
      flex-direction: column;
      gap: 1rem;
      animation: fade-up 0.5s ease both;
    }
    #result-section.visible { display: flex; }

    @keyframes fade-up {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .result-header {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent4);
    }
    .result-header::before { content: '✦'; font-size: 1rem; }

    .task-name {
      font-size: clamp(1.3rem, 3vw, 1.9rem);
      font-weight: 700;
      line-height: 1.25;
      background: linear-gradient(120deg, #f0e6ff, #d8b4fe, #f9a8d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Metrics row ─────────────────────────────────────────────────── */
    .metrics-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .metric-chip {
      background: rgba(0,0,0,0.3);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 1rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 4px;
      position: relative;
      overflow: hidden;
    }
    .metric-chip::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 2px;
    }
    .metric-chip.urgency::before { background: linear-gradient(90deg, var(--red), var(--yellow)); }
    .metric-chip.time::before    { background: linear-gradient(90deg, var(--accent4), var(--accent2)); }

    .metric-label {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .metric-value {
      font-size: 1.8rem;
      font-weight: 800;
      line-height: 1;
    }
    .metric-unit { font-size: 0.8rem; font-weight: 400; color: var(--text-muted); margin-left: 3px; }

    /* Urgency bar */
    .urgency-bar-track {
      width: 100%;
      height: 5px;
      background: rgba(255,255,255,0.08);
      border-radius: 999px;
      margin-top: 6px;
      overflow: hidden;
    }
    .urgency-bar-fill {
      height: 100%;
      border-radius: 999px;
      transition: width 1s cubic-bezier(0.16,1,0.3,1);
      background: linear-gradient(90deg, var(--yellow), var(--red));
    }

    /* ── Micro-action card ───────────────────────────────────────────── */
    .micro-action-card {
      background: linear-gradient(135deg, rgba(124,58,237,0.15), rgba(236,72,153,0.1));
      border: 1px solid rgba(168,85,247,0.25);
      border-radius: 18px;
      padding: 1.25rem 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .micro-action-card::before {
      content: '';
      position: absolute;
