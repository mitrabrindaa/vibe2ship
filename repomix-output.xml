<file path="src/app/globals.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
@import "tailwindcss";

/* ── Reset & base ──────────────────────────────────────────────────────── */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --bg-start:       #0d0100;
  --bg-mid:         #120a00;
  --bg-end:         #0a0000;
  --accent-fire:    #e85d04;
  --accent-orange:  #f48c06;
  --accent-crimson: #d62828;
  --accent-amber:   #ffba08;
  --accent-teal:    #06b6d4;
  --glass-bg:       rgba(255, 255, 255, 0.04);
  --glass-border:   rgba(255, 255, 255, 0.10);
  --text-primary:   #fff8f0;
  --text-muted:     rgba(255, 248, 240, 0.55);
}

html, body {
  min-height: 100%;
  font-family: 'Inter', sans-serif;
  color: var(--text-primary);
  overflow-x: hidden;
  background: linear-gradient(145deg, var(--bg-start) 0%, var(--bg-mid) 50%, var(--bg-end) 100%);
}

/* ── Wave canvas ──────────────────────────────────────────────────────── */
#wave-canvas {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
  opacity: 0.30;
}

/* ── Ambient orbs — reddish-orange at top & bottom ─────────────────── */
.orb {
  position: fixed;
  border-radius: 50%;
  filter: blur(100px);
  z-index: 0;
  pointer-events: none;
  animation: orb-drift 20s ease-in-out infinite alternate;
}
/* Top edge — deep orange */
.orb-top {
  width: 600px;
  height: 400px;
  background: radial-gradient(circle, rgba(232, 93, 4, 0.55), transparent 70%);
  top: -160px;
  left: 10%;
  animation-delay: 0s;
}
/* Bottom edge — crimson-red */
.orb-bottom {
  width: 550px;
  height: 380px;
  background: radial-gradient(circle, rgba(214, 40, 40, 0.50), transparent 70%);
  bottom: -140px;
  right: 8%;
  animation-delay: -8s;
}
/* Mid accent — amber */
.orb-mid {
  width: 320px;
  height: 320px;
  background: radial-gradient(circle, rgba(255, 186, 8, 0.22), transparent 70%);
  top: 40%;
  left: 55%;
  animation-delay: -14s;
}

@keyframes orb-drift {
  0%   { transform: translate(0, 0) scale(1); }
  50%  { transform: translate(24px, -36px) scale(1.08); }
  100% { transform: translate(-18px, 18px) scale(0.94); }
}

/* ── Layout ───────────────────────────────────────────────────────────── */
.app-layout {
  position: relative;
  z-index: 1;
  display: flex;
  height: 100vh;
  overflow: hidden;
}

/* ── Left control panel ───────────────────────────────────────────────── */
.control-panel {
  width: 400px;
  min-width: 360px;
  max-width: 420px;
  height: 100vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  padding: 2rem 1.5rem;
  border-right: 1px solid rgba(255, 255, 255, 0.07);
  background: rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(12px);
  scrollbar-width: thin;
  scrollbar-color: rgba(232, 93, 4, 0.3) transparent;
}

/* ── Right calendar view ──────────────────────────────────────────────── */
.calendar-panel {
  flex: 1;
  height: 100vh;
  overflow: hidden;
  padding: 1.5rem 1.5rem 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
}

/* ── Glass card ───────────────────────────────────────────────────────── */
.glass-card {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 20px;
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  padding: 1.5rem;
  box-shadow:
    0 0 0 1px rgba(255, 255, 255, 0.04),
    0 20px 60px rgba(0, 0, 0, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.07);
  transition: box-shadow 0.3s ease;
}
.glass-card:hover {
  box-shadow:
    0 0 0 1px rgba(232, 93, 4, 0.2),
    0 20px 60px rgba(0, 0, 0, 0.55),
    0 0 40px rgba(232, 93, 4, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.07);
}

/* ── Badge ────────────────────────────────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-orange);
  background: rgba(244, 140, 6, 0.12);
  border: 1px solid rgba(244, 140, 6, 0.28);
  border-radius: 999px;
  padding: 4px 12px;
}

/* ── Gradient heading ─────────────────────────────────────────────────── */
.gradient-heading {
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800;
  line-height: 1.1;
  background: linear-gradient(135deg, #ffedcc 0%, #f48c06 40%, #e85d04 75%, #d62828 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.4rem;
}

.subtitle {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ── Sync button ──────────────────────────────────────────────────────── */
.sync-btn {
  width: 100%;
  padding: 0.9rem 1.5rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: #fff;
  background: linear-gradient(135deg, var(--accent-crimson) 0%, var(--accent-fire) 50%, var(--accent-orange) 100%);
  border: none;
  border-radius: 14px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: transform 0.18s, box-shadow 0.18s;
  box-shadow: 0 4px 24px rgba(232, 93, 4, 0.45);
}
.sync-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 55%);
  border-radius: inherit;
}
.sync-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(232, 93, 4, 0.6);
}
.sync-btn:active:not(:disabled) { transform: translateY(0); }
.sync-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

/* ── Spinner ──────────────────────────────────────────────────────────── */
.spinner {
  width: 17px;
  height: 17px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Task list ────────────────────────────────────────────────────────── */
.task-list-header {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-orange);
  margin-bottom: 0.6rem;
}
.task-pill {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0.7rem 1rem;
  background: rgba(0,0,0,0.25);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}
.task-pill-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Event count badge ───────────────────────────────────────────────── */
.events-meta {
  font-size: 0.78rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 6px;
}
.events-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(232, 93, 4, 0.2);
  border: 1px solid rgba(232, 93, 4, 0.35);
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--accent-fire);
  padding: 1px 9px;
}

/* ── Error banner ─────────────────────────────────────────────────────── */
.error-banner {
  background: rgba(214, 40, 40, 0.12);
  border: 1px solid rgba(214, 40, 40, 0.3);
  border-radius: 12px;
  padding: 0.85rem 1.1rem;
  color: #fca5a5;
  font-size: 0.875rem;
  animation: fade-up 0.4s ease both;
}

@keyframes fade-up {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; }
  50%       { opacity: 0.15; }
}


/* ── Calendar panel header ───────────────────────────────────────────── */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.calendar-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 8px;
}
.calendar-title span {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-muted);
}

/* ── FullCalendar dark theme overrides ──────────────────────────────── */
.fc {
  height: 100% !important;
  font-family: 'Inter', sans-serif !important;
  font-size: 0.82rem !important;
  color: var(--text-primary) !important;
}
.fc-theme-standard .fc-scrollgrid { border-color: rgba(255,255,255,0.08) !important; }
.fc-theme-standard td, .fc-theme-standard th { border-color: rgba(255,255,255,0.07) !important; }
.fc-col-header-cell-cushion { color: var(--text-muted) !important; font-weight: 600 !important; font-size: 0.75rem !important; text-transform: uppercase !important; letter-spacing: 0.06em !important; text-decoration: none !important; }
.fc-daygrid-day-number { color: var(--text-muted) !important; text-decoration: none !important; }
.fc-timegrid-slot-label-cushion { color: rgba(255,255,255,0.3) !important; font-size: 0.72rem !important; }
.fc-timegrid-now-indicator-line { border-color: var(--accent-fire) !important; border-width: 2px !important; }
.fc-timegrid-now-indicator-arrow { border-top-color: var(--accent-fire) !important; border-bottom-color: var(--accent-fire) !important; }
.fc .fc-button-primary { background: rgba(232, 93, 4, 0.15) !important; border: 1px solid rgba(232, 93, 4, 0.3) !important; color: var(--accent-orange) !important; font-weight: 600 !important; font-size: 0.78rem !important; border-radius: 8px !important; transition: all 0.2s !important; }
.fc .fc-button-primary:hover { background: rgba(232, 93, 4, 0.3) !important; }
.fc .fc-button-primary:not(:disabled).fc-button-active, .fc .fc-button-primary:not(:disabled):active { background: rgba(232, 93, 4, 0.4) !important; }
.fc .fc-toolbar-title { font-size: 1rem !important; font-weight: 700 !important; color: var(--text-primary) !important; }
.fc-event { border-radius: 8px !important; border: none !important; padding: 2px 6px !important; font-weight: 600 !important; font-size: 0.78rem !important; cursor: pointer !important; }
.fc-event-title { font-weight: 600 !important; }
.fc-event-time { font-size: 0.7rem !important; opacity: 0.85 !important; }
.fc-scrollgrid-sync-inner { background: rgba(0,0,0,0.2) !important; }
.fc-timegrid-col { background: transparent !important; }
.fc-day-today { background: rgba(232, 93, 4, 0.05) !important; }
.fc-highlight { background: rgba(232, 93, 4, 0.1) !important; }
/* Selection mirror (drag to create) */
.fc-timegrid-event.fc-event-mirror { background: rgba(56, 189, 248, 0.35) !important; border: 2px dashed #38bdf8 !important; border-radius: 8px !important; }

/* ── Settings grid ───────────────────────────────────────────────────── */
.settings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
.settings-field {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.settings-field--full {
  grid-column: 1 / -1;
}
.settings-label {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.settings-input {
  width: 100%;
  padding: 0.55rem 0.75rem;
  background: rgba(0, 0, 0, 0.35);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  color-scheme: dark;
}
.settings-input:focus {
  border-color: rgba(232, 93, 4, 0.5);
  box-shadow: 0 0 0 3px rgba(232, 93, 4, 0.12);
}
.settings-input[type="number"]::-webkit-inner-spin-button {
  opacity: 0.4;
  filter: invert(1);
}

/* ── Manual deadline button ──────────────────────────────────────────── */
.manual-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0.45rem 0.9rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: #38bdf8;
  background: rgba(56, 189, 248, 0.1);
  border: 1px solid rgba(56, 189, 248, 0.3);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.18s ease;
  white-space: nowrap;
}
.manual-btn:hover {
  background: rgba(56, 189, 248, 0.2);
  border-color: rgba(56, 189, 248, 0.5);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(56, 189, 248, 0.2);
}
.manual-btn:active { transform: translateY(0); }

/* ── Calendar legend ─────────────────────────────────────────────────── */
.calendar-legend {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
  font-size: 0.72rem;
  color: var(--text-muted);
}
.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 3px;
  flex-shrink: 0;
}
.legend-label {
  font-weight: 500;
  margin-right: 0.4rem;
}
.legend-hint {
  opacity: 0.5;
  font-style: italic;
}

/* ════════════════════════════════════════════════════════════════════════
   DEADLINE MODAL
   ════════════════════════════════════════════════════════════════════════ */

/* ── Backdrop ─────────────────────────────────────────────────────────── */
.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 100;
  animation: backdrop-in 0.2s ease both;
}
@keyframes backdrop-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── Panel ────────────────────────────────────────────────────────────── */
.modal-panel {
  position: fixed;
  top: 0;
  right: 0;
  height: 100vh;
  width: 480px;
  max-width: 95vw;
  z-index: 101;
  display: flex;
  flex-direction: column;
  background: linear-gradient(160deg, rgba(18, 6, 2, 0.97) 0%, rgba(10, 4, 0, 0.98) 100%);
  border-left: 1px solid rgba(255, 255, 255, 0.09);
  box-shadow: -24px 0 80px rgba(0, 0, 0, 0.7), -1px 0 0 rgba(232, 93, 4, 0.15);
  animation: panel-slide-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  overflow: hidden;
}
@keyframes panel-slide-in {
  from { transform: translateX(100%); opacity: 0.5; }
  to   { transform: translateX(0);    opacity: 1; }
}

/* ── Header ───────────────────────────────────────────────────────────── */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 1.5rem 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  flex-shrink: 0;
  background: rgba(232, 93, 4, 0.04);
}
.modal-title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
}
.modal-title-icon {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--accent-crimson), var(--accent-fire));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(232, 93, 4, 0.4);
}
.modal-close-btn {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.18s ease;
}
.modal-close-btn:hover {
  background: rgba(214, 40, 40, 0.15);
  border-color: rgba(214, 40, 40, 0.35);
  color: #fca5a5;
}

/* ── Scrollable body ──────────────────────────────────────────────────── */
.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(232, 93, 4, 0.3) transparent;
}

/* ── Field ────────────────────────────────────────────────────────────── */
.modal-field {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.modal-label {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.modal-required {
  color: var(--accent-fire);
}
.modal-input {
  width: 100%;
  padding: 0.6rem 0.85rem;
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 10px;
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 500;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  color-scheme: dark;
}
.modal-input:focus {
  border-color: rgba(232, 93, 4, 0.5);
  box-shadow: 0 0 0 3px rgba(232, 93, 4, 0.12);
}
.modal-input--error {
  border-color: rgba(214, 40, 40, 0.55) !important;
  box-shadow: 0 0 0 3px rgba(214, 40, 40, 0.1) !important;
}
.modal-input--sm {
  padding: 0.45rem 0.65rem;
  font-size: 0.82rem;
  border-radius: 8px;
}
.modal-error-msg {
  font-size: 0.72rem;
  color: #f87171;
  margin-top: 1px;
}
.modal-textarea {
  width: 100%;
  padding: 0.65rem 0.85rem;
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 10px;
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  line-height: 1.6;
  font-weight: 400;
  outline: none;
  resize: vertical;
  min-height: 80px;
  transition: border-color 0.2s, box-shadow 0.2s;
  color-scheme: dark;
}
.modal-textarea::placeholder { color: rgba(255, 255, 255, 0.2); }
.modal-textarea:focus {
  border-color: rgba(232, 93, 4, 0.5);
  box-shadow: 0 0 0 3px rgba(232, 93, 4, 0.1);
}

/* ── Date+Time row ────────────────────────────────────────────────────── */
.modal-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.85rem;
}

/* ── Reminders section ────────────────────────────────────────────────── */
.modal-section {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding-top: 0.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}
.modal-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.modal-section-title {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--text-primary);
}
.modal-reminder-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(232, 93, 4, 0.25);
  border: 1px solid rgba(232, 93, 4, 0.4);
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--accent-fire);
}
.modal-add-reminder-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 0.35rem 0.8rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent-orange);
  background: rgba(244, 140, 6, 0.1);
  border: 1px solid rgba(244, 140, 6, 0.28);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.18s ease;
}
.modal-add-reminder-btn:hover {
  background: rgba(244, 140, 6, 0.2);
  border-color: rgba(244, 140, 6, 0.45);
}
.modal-empty-hint {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.2);
  font-style: italic;
  text-align: center;
  padding: 0.5rem 0;
}

/* ── Reminder rows ────────────────────────────────────────────────────── */
.modal-reminders-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.reminder-row {
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
  padding: 0.85rem 1rem;
  background: rgba(0, 0, 0, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 12px;
  position: relative;
  animation: fade-up 0.22s ease both;
}
.reminder-index {
  position: absolute;
  top: -9px;
  left: 12px;
  background: rgba(232, 93, 4, 0.2);
  border: 1px solid rgba(232, 93, 4, 0.35);
  border-radius: 999px;
  font-size: 0.62rem;
  font-weight: 700;
  color: var(--accent-fire);
  padding: 1px 7px;
}

