  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 8px;
  border: 1px solid rgba(214, 40, 40, 0.2);
  background: rgba(214, 40, 40, 0.08);
  color: rgba(248, 113, 113, 0.6);
  cursor: pointer;
  transition: all 0.15s ease;
}
.reminder-delete-btn:hover {
  background: rgba(214, 40, 40, 0.2);
  border-color: rgba(214, 40, 40, 0.4);
  color: #f87171;
}

/* ── Footer ───────────────────────────────────────────────────────────── */
.modal-footer {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.07);
  flex-shrink: 0;
  background: rgba(0, 0, 0, 0.2);
}
.modal-cancel-btn {
  flex: 1;
  padding: 0.7rem 1rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text-muted);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.18s ease;
}
.modal-cancel-btn:hover {
  background: rgba(255, 255, 255, 0.09);
  color: var(--text-primary);
}
.modal-submit-btn {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0.7rem 1rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.92rem;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--accent-crimson) 0%, var(--accent-fire) 55%, var(--accent-orange) 100%);
  border: none;
  border-radius: 12px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: transform 0.18s, box-shadow 0.18s;
  box-shadow: 0 4px 20px rgba(232, 93, 4, 0.4);
}
.modal-submit-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.16) 0%, transparent 55%);
  border-radius: inherit;
}
.modal-submit-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 28px rgba(232, 93, 4, 0.55);
}
.modal-submit-btn:active { transform: translateY(0); }
